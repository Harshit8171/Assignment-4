-- Moderate level --

1.  Select e.emoloyee_name, d.department_name
    from employee as e
    INNER JOIN depertment as d
    ON e.department_ID = d.department;

2.  Select e.employee_name, p.project_name
    from employeeas as e
    LEFT JOIN projects as p
    ON e.project_id = p.project_id;

3.   Select d.department_name, e.employee_name
     from employee as e
     RIGHT JOIN department as d
     ON e.department_id = d.department_id;

4.   Select e.empyolee_name, e.salary, d.department_name
     from employee as e
     INNER JOIN department as d
     ON e.department_id = d.department_id;

5.  Select e.employee_name, d.department_name
    from employee as e
    LEFT JOIN department as d
    ON e.empyoyee_id = d.department_id;

6.  Select p.project_name, e.employee_name
    from project as p
    INNER JOIN employee as e
    ON p.prject_id = e.project_id;

7.  SELECT d.department_name, COUNT(e.employee_id) AS total_employees
    FROM departments as d
    LEFT JOIN employees as e
    ON d.department_id = e.department_id
    GROUP BY d.department_name;

8.  SELECT e.employee_name, e.salary, d.department_name
    FROM employees as e
    INNER JOIN departments as d
    ON e.department_id = d.department_id
    WHERE e.salary > 40000;

9.  SELECT e.employee_name, p.project_name
    FROM employees as e
    LEFT JOIN projects as p
    ON e.project_id = p.project_id;

10.   SELECT e.employee_name, d.department_name
      FROM employees as e
      INNER JOIN departments as d
      ON e.department_id = d.department_id
      WHERE d.department_name = 'IT';

-- Intermediate Level --

1.  SELECT e.employee_name
    FROM employees as e
    LEFT JOIN projects as p
    ON e.project_id = p.project_id
    WHERE p.project_id IS NULL;

2.  SELECT employee_name, salary
    FROM employees
    WHERE salary > (
    SELECT AVG(salary)
    FROM employees
    );

3.  SELECT d.department_name
    FROM departments as d
    LEFT JOIN employees as e
    ON d.department_id = e.department_id
    WHERE e.employee_id IS NULL;

4.  SELECT employee_name
    FROM employees
    WHERE department_id = (
    SELECT department_id
    FROM employees
    WHERE employee_name = 'John'
    );

5.  SELECT department_id, MAX(salary) AS highest_salary
    FROM employees
    GROUP BY department_id;

6.  SELECT employee_name, salary, department_id
    FROM employees as e
    WHERE salary = (
    SELECT MAX(salary)
    FROM employees
    WHERE department_id = e.department_id
    );

7.  SELECT employee_name, salary, department_id
    FROM employees as e
    WHERE salary = (
    SELECT MAX(salary)
    FROM employees
    WHERE department_id = e.department_id
    );

8.  SELECT department_id, AVG(salary) AS avg_salary
    FROM employees
    GROUP BY department_id
    HAVING AVG(salary) > 60000;

9.  SELECT employee_name, salary, department_id
    FROM employees as e
    WHERE salary > (
    SELECT AVG(salary)
    FROM employees
    WHERE department_id = e.department_id
    );

10.  SELECT employee_name
    FROM employees
    WHERE department_id IS NULL;

-- Advanced Level --

1.  SELECT employee_name, salary, department_id
    FROM employees as e
    WHERE salary > (
    SELECT AVG(salary)
    FROM employees
    WHERE department_id = e.department_id
    );

2.  SELECT department_id, AVG(salary) AS avg_salary
    FROM employees
    GROUP BY department_id
    ORDER BY avg_salary DESC
    LIMIT 1;

3.  SELECT employee_id
    FROM employee_projects
    GROUP BY employee_id
    HAVING COUNT(project_id) > 1;

4.  SELECT *
    FROM (
    SELECT employee_name, salary, department_id,
           RANK() OVER (PARTITION BY department_id ORDER BY salary DESC) AS rank_num
    FROM employees
    ) t
    WHERE rank_num <= 3;

5.  SELECT department_id
    FROM employees
    GROUP BY department_id
    HAVING MIN(salary) >= 30000;

6.  SELECT employee_name, salary, department_id
    FROM (
    SELECT employee_name, salary, department_id,
           DENSE_RANK() OVER (PARTITION BY department_id ORDER BY salary DESC) AS rnk
    FROM employees
    ) t
    WHERE rnk = 2;

7.  SELECT employee_name, department_id
    FROM employees
    WHERE department_id IN (
    SELECT department_id
    FROM employees
    GROUP BY department_id
    HAVING COUNT(*) > 5
    );

8.  SELECT employee_name
    FROM employees
    WHERE employee_id IN (
    SELECT employee_id
    FROM employee_projects
    WHERE project_id = (
        SELECT project_id
        FROM employee_projects ep
        JOIN employees as e
        ON ep.employee_id = e.employee_id
        WHERE e.employee_name = 'John'
    )
);

9.  SELECT employee_name, salary
    FROM employees
    WHERE salary > (
    SELECT AVG(salary)
    FROM employees
    );

10.  SELECT d.department_name,
       SUM(e.salary) AS total_salary,
       COUNT(e.employee_id) AS total_employees
    FROM departments as d
    JOIN employees as e
    ON d.department_id = e.department_id
    GROUP BY d.department_name;
